---
import ThemeToggle from './ThemeToggle.svelte';
import MobileMenu from './MobileMenu.svelte';

const links = [
  { href: '/', label: 'Home' },
  { href: '/#about', label: 'About' },
  { href: '/portfolio', label: 'Portfolio' },
  { href: '/#skills', label: 'Skills' },
  { href: '/#contact', label: 'Contact' },
];
---

<header
  class="fixed top-0 left-0 w-full z-50 border-b border-[var(--border-color)]
         bg-[var(--bg-primary)]/80 backdrop-blur-xl transition-colors duration-300"
>
  <nav class="max-w-7xl mx-auto px-5 h-[73px] flex items-center justify-between">
    <a
      href="/"
      class="text-2xl font-bold text-primary transition-all duration-300
             hover:opacity-80 active:scale-95"
      aria-label="Home"
    >
      pmec<span class="text-[var(--text-secondary)] font-normal">.dev</span>
    </a>

    <ul class="hidden md:flex items-center gap-1">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="relative px-4 py-2 rounded-lg text-sm font-medium
                     text-[var(--text-secondary)] transition-all duration-200
                     hover:text-primary hover:bg-primary/5
                     after:absolute after:bottom-0 after:left-1/2 after:-translate-x-1/2
                     after:w-0 after:h-0.5 after:bg-primary after:rounded-full
                     after:transition-all after:duration-300
                     hover:after:w-6 focus-ring"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-3">
      <ThemeToggle client:load />
      <MobileMenu client:load />
    </div>
  </nav>
</header>
