---
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';
import TypeWriter from '../components/TypeWriter.svelte';
import SkillBar from '../components/SkillBar.svelte';
import ContactForm from '../components/ContactForm.svelte';
import ProjectGrid from '../components/ProjectGrid.svelte';
import CardSwap from '../components/CardSwap.svelte';
import FlowingMenu from '../components/FlowingMenu.svelte';

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .map((p) => ({ slug: p.slug, ...p.data }));

const skills = [
  { name: 'JavaScript / TypeScript', level: 90 },
  { name: 'HTML / CSS', level: 95 },
  { name: 'React / Next.js', level: 85 },
  { name: 'Svelte / Astro', level: 80 },
  { name: 'Node.js / Express', level: 80 },
  { name: 'Python / FastAPI', level: 75 },
  { name: 'PostgreSQL / MongoDB', level: 70 },
  { name: 'Git / CI/CD', level: 85 },
];

const typingTexts = [
  'Building amazing digital experiences...',
  'Lifting some heavy weights...',
  'Chilling with friends...',
  'Always learning new ways to make life easier...',
];

const aboutCards = [
  {
    title: 'Developer',
    subtitle: 'Passionate about code',
    description: 'Currently studying at Windesheim Almere, focusing on modern web technologies and software engineering principles.',
    gradient: 'from-primary to-primary-700',
    icon: '<svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"/></svg>',
  },
  {
    title: 'Fitness',
    subtitle: 'Strength & discipline',
    description: 'I hit the gym 4 times a week. Fitness teaches me discipline, consistency, and the importance of pushing personal limits.',
    gradient: 'from-emerald-500 to-teal-600',
    icon: '<svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>',
  },
  {
    title: 'Gamer',
    subtitle: 'Competitive spirit',
    description: 'Former top 150 Counter-Strike player in the Netherlands. Gaming taught me teamwork and quick decision-making.',
    gradient: 'from-orange-500 to-amber-500',
    icon: '<svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14.25 6.087c0-.355.186-.676.401-.959.221-.29.349-.634.349-1.003 0-1.036-1.007-1.875-2.25-1.875s-2.25.84-2.25 1.875c0 .369.128.713.349 1.003.215.283.401.604.401.959v0a.64.64 0 01-.657.643 48.39 48.39 0 01-4.163-.3c.186 1.613.293 3.25.315 4.907a.656.656 0 01-.658.663v0c-.355 0-.676-.186-.959-.401a1.647 1.647 0 00-1.003-.349c-1.036 0-1.875 1.007-1.875 2.25s.84 2.25 1.875 2.25c.369 0 .713-.128 1.003-.349.283-.215.604-.401.959-.401v0c.31 0 .555.26.532.57a48.039 48.039 0 01-.642 5.056c1.518.19 3.058.309 4.616.354a.64.64 0 00.657-.643v0c0-.355-.186-.676-.401-.959a1.647 1.647 0 01-.349-1.003c0-1.035 1.008-1.875 2.25-1.875 1.243 0 2.25.84 2.25 1.875 0 .369-.128.713-.349 1.003-.215.283-.4.604-.4.959v0c0 .333.277.599.61.58a48.1 48.1 0 005.427-.63 48.05 48.05 0 00.582-4.717.532.532 0 00-.533-.57v0c-.355 0-.676.186-.959.401-.29.221-.634.349-1.003.349-1.035 0-1.875-1.007-1.875-2.25s.84-2.25 1.875-2.25c.37 0 .713.128 1.003.349.283.215.604.401.959.401v0a.656.656 0 00.658-.663 48.422 48.422 0 00-.37-5.36c-1.886.342-3.81.574-5.766.689a.578.578 0 01-.61-.58v0z"/></svg>',
  },
];

const siteLinks = [
  {
    text: 'pmec.dev',
    href: 'https://pmec.dev',
    image: 'https://images.unsplash.com/photo-1461749280684-dccba630e2f6?w=400&h=200&fit=crop',
  },
  {
    text: 'Fittrack',
    href: 'https://fit.pmec.dev',
    image: 'https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=400&h=200&fit=crop',
  },
  {
    text: 'Statsmec',
    href: 'https://stats.pmec.dev',
    image: 'https://images.unsplash.com/photo-1542751371-adc38448a05e?w=400&h=200&fit=crop',
  },
];
---

<MainLayout title="Pedro Eduardo Cardoso - Software Developer">
  <!-- Hero Section -->
  <section id="home" class="relative min-h-screen flex items-center pt-[73px]">
    <div class="relative z-10 max-w-7xl mx-auto px-5 py-20 w-full">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="order-2 lg:order-1">
          <div class="reveal">
            <p class="text-sm font-semibold tracking-widest uppercase text-primary mb-4">
              Software Developer
            </p>
            <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight mb-6">
              <span class="text-gradient">Pedro Eduardo</span>
              <br />
              <span class="text-[var(--text-primary)]">Cardoso</span>
            </h1>
          </div>

          <div class="reveal stagger-1">
            <p class="text-lg text-[var(--text-secondary)] mb-4">
              From Portugal, building in the Netherlands
            </p>
          </div>

          <div class="reveal stagger-2 mb-6 h-8">
            <TypeWriter texts={typingTexts} className="text-lg md:text-xl" client:visible />
          </div>

          <div class="reveal stagger-3">
            <p class="text-[var(--text-secondary)] max-w-lg mb-8">
              Passionate about coding, fitness, and competitive gaming.
              Currently studying Software Development at Windesheim Almere and
              building tools that solve real problems.
            </p>
          </div>

          <div class="reveal stagger-4 flex flex-wrap gap-4">
            <a
              href="#contact"
              class="group inline-flex items-center gap-2 px-7 py-3.5 rounded-xl
                     font-semibold text-white bg-gradient-to-r from-primary to-primary-500
                     transition-all duration-300 hover:-translate-y-0.5
                     hover:shadow-xl hover:shadow-primary/25
                     active:translate-y-0 focus-ring"
            >
              Get In Touch
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
              </svg>
            </a>
            <a
              href="/portfolio"
              class="inline-flex items-center gap-2 px-7 py-3.5 rounded-xl
                     font-semibold border-2 border-primary text-primary
                     transition-all duration-300 hover:bg-primary hover:text-white
                     hover:-translate-y-0.5 active:translate-y-0 focus-ring"
            >
              View Portfolio
            </a>
          </div>
        </div>

        <div class="order-1 lg:order-2 flex justify-center reveal">
          <div class="relative">
            <div
              class="absolute -inset-4 rounded-full bg-gradient-to-br from-primary/20 to-secondary/20
                     blur-2xl animate-glow"
              aria-hidden="true"
            ></div>
            <img
              src="/image/background.jpg"
              alt="Pedro Eduardo Cardoso"
              class="relative w-64 h-64 sm:w-72 sm:h-72 lg:w-80 lg:h-80
                     rounded-full object-cover border-4 border-primary/50
                     shadow-2xl shadow-primary/20 animate-glow"
              width="320"
              height="320"
              loading="eager"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 hidden lg:block" aria-hidden="true">
      <div class="w-6 h-10 rounded-full border-2 border-[var(--text-secondary)]/30 flex justify-center pt-2">
        <div class="w-1 h-3 rounded-full bg-[var(--text-secondary)]/50 animate-bounce"></div>
      </div>
    </div>
  </section>

  <!-- About Section with CardSwap -->
  <section id="about" class="section-padding bg-[var(--bg-secondary)] transition-colors duration-300">
    <div class="max-w-7xl mx-auto px-5">
      <h2 class="text-center text-4xl font-bold mb-6 text-primary reveal">About Me</h2>
      <p class="text-center text-[var(--text-secondary)] max-w-2xl mx-auto mb-16 reveal stagger-1">
        A 23-year-old software developer with a passion for creating innovative
        digital solutions. Born in Portugal and now living in the Netherlands, I
        bring a unique international perspective to my work.
      </p>

      <div class="flex justify-center reveal stagger-2">
        <CardSwap
          cards={aboutCards}
          cardWidth={360}
          cardHeight={220}
          delay={4000}
          pauseOnHover={true}
          client:visible
        />
      </div>
    </div>
  </section>

  <!-- Bento Grid: Projects + Sites -->
  <section class="section-padding">
    <div class="max-w-7xl mx-auto px-5">
      <h2 class="text-center text-4xl font-bold mb-4 text-primary reveal">
        What I'm Building
      </h2>
      <p class="text-center text-[var(--text-secondary)] max-w-xl mx-auto mb-12 reveal stagger-1">
        Projects, sites, and things I'm working on.
      </p>

      <div class="grid grid-cols-1 lg:grid-cols-5 gap-6 lg:gap-8">
        <!-- Projects Grid: spans 3 columns -->
        <div class="lg:col-span-3 reveal stagger-1">
          <ProjectGrid projects={featuredProjects} showFilters={false} client:visible />
        </div>

        <!-- Flowing Menu: spans 2 columns -->
        <div class="lg:col-span-2 reveal stagger-2">
          <div class="sticky top-24">
            <h3 class="text-lg font-semibold text-[var(--text-primary)] mb-4">My Sites</h3>
            <FlowingMenu items={siteLinks} marqueeSpeed={10} client:visible />

            <div class="mt-8 text-center">
              <a
                href="/portfolio"
                class="group inline-flex items-center gap-2 px-7 py-3.5 rounded-xl
                       font-semibold border-2 border-primary text-primary
                       transition-all duration-300 hover:bg-primary hover:text-white
                       hover:-translate-y-0.5 active:translate-y-0 focus-ring"
              >
                View All Projects
                <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Skills Section -->
  <section id="skills" class="section-padding bg-[var(--bg-secondary)] transition-colors duration-300">
    <div class="max-w-7xl mx-auto px-5">
      <h2 class="text-center text-4xl font-bold mb-4 text-primary reveal">
        Skills & Technologies
      </h2>
      <p class="text-center text-[var(--text-secondary)] max-w-xl mx-auto mb-12 reveal stagger-1">
        Technologies I work with daily to build modern web applications.
      </p>

      <div class="max-w-3xl mx-auto">
        <SkillBar skills={skills} client:visible />
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="section-padding">
    <div class="max-w-7xl mx-auto px-5">
      <h2 class="text-center text-4xl font-bold mb-4 text-primary reveal">
        Get In Touch
      </h2>
      <p class="text-center text-[var(--text-secondary)] max-w-xl mx-auto mb-12 reveal stagger-1">
        Have a project in mind, want to collaborate, or just want to say hi?
        I'd love to hear from you.
      </p>

      <div class="max-w-lg mx-auto reveal stagger-2">
        <div class="glass-card !hover:transform-none">
          <ContactForm client:visible />
        </div>
      </div>
    </div>
  </section>
</MainLayout>
