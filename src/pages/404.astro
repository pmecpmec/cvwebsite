---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Page not found - Pedro Eduardo Cardoso" description="The page you're looking for doesn't exist.">
  <section class="min-h-[80vh] flex items-center justify-center px-5 pt-[73px]">
    <div class="text-center max-w-md">
      <p class="text-6xl font-bold text-primary mb-4" aria-hidden="true">404</p>
      <h1 class="text-2xl font-bold text-[var(--text-primary)] mb-3">Page not found</h1>
      <p class="text-[var(--text-secondary)] mb-8">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-white
               bg-gradient-to-r from-primary to-primary-500
               transition-all duration-300 hover:-translate-y-0.5
               hover:shadow-lg hover:shadow-primary/25 focus-ring"
      >
        Back to home
      </a>
    </div>
  </section>
</MainLayout>
